# Extra applications carried by the LEDE-oriented profiles before config
# normalization.

CONFIG_PACKAGE_luci-app-msd_lite=y
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-app-mwan3helper=y
CONFIG_PACKAGE_luci-app-openvpn-server=y
CONFIG_PACKAGE_luci-app-qbittorrent=y
CONFIG_PACKAGE_luci-app-syncdial=y
CONFIG_PACKAGE_ipv6helper=y

# LEDE autosamba and samba4-server both install /etc/hotplug.d/block/20-smb.
# Keep the LuCI Samba4 stack and drop autosamba to avoid package/install clash.
# CONFIG_PACKAGE_autosamba is not set

# Current coolsnowwolf/lede master fails to build vlmcsd on x86_64 with GCC 13.
# Keep it disabled until the upstream package build is fixed.
# CONFIG_PACKAGE_luci-app-vlmcsd is not set
# CONFIG_PACKAGE_vlmcsd is not set
