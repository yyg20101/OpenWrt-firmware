# Network performance and latency stability helpers.
#
# BBR improves TCP throughput on variable-latency WAN links. SQM/CAKE and IFB
# add optional queue management support for reducing bufferbloat; they do not
# shape traffic until configured by the user.

CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_kmod-sched=y
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_kmod-ifb=y
CONFIG_PACKAGE_sqm-scripts=y
CONFIG_PACKAGE_luci-app-sqm=y
